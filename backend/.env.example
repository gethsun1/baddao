# Backend Environment — Copy this to .env and fill in values
# NEVER commit the actual .env file

# ── Blockchain ────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
WS_RPC_URL=wss://mainnet.infura.io/ws/v3/YOUR_KEY
CHAIN_ID=1
START_BLOCK=0

# Protocol contracts
PROTOCOL_FEE_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
BAD_DAO_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Relayer ───────────────────────────────────────────────────────────────────
# AES-256 encrypted private key — NEVER store plaintext
RELAYER_ENCRYPTED_KEY=ENCRYPTED_PLACEHOLDER
RELAYER_KEY_PASSPHRASE=YOUR_PASSPHRASE_FROM_VAULT

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bad_dao

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_SECRET=your-api-secret-here

# ── Webhook ───────────────────────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=your-webhook-signing-secret
